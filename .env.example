# PayMe API Configuration
CORE_API_URL=https://your-payme-api-url.com
DEFAULT_SELLER_PAYME_ID=your-seller-id

# PayMe API Key (required for Apple Pay)
# Get this from your PayMe dashboard Settings page
PAYME_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Test Mode (set to 'true' for test environment, 'false' for production)
PAYME_TEST_MODE=true

# Apple Pay Configuration
# Apple Pay Merchant ID (e.g., merchant.paymeproduction)
# This will be provided by your PayMe integration manager
APPLE_PAY_MERCHANT_ID=merchant.paymeproduction

# Apple Pay Certificate (required for domain verification)
# This is the content of apple-developer-merchantid-domain-association file
APPLE_PAY_CERTIFICATE=your-apple-pay-certificate-content

# Domain Configuration
# When set, this domain gets production behavior: auto-determined server URLs, no Server URL / staging SDK fields
PROD_DOMAIN=wrapper.payme.io

# Apple Pay Certificate for Production Domain
APPLE_PAY_CERTIFICATE_PROD=your-production-apple-pay-certificate-content

# Server Configuration
PORT=3000
<div class="container form-container">
    <div class="form-wrapper">
        <h1>Generate PayMe Sale</h1>
        <form id="saleForm" action="/generate-sale" method="POST">
            <div class="row">
                <div class="form-group">
                    <label for="sale_price">Sale Price</label>
                    <input type="number" id="sale_price" name="sale_price" required value="100" min="1" step="0.01">
                </div>

                <div class="form-group">
                    <label for="currency">Currency</label>
                    <select id="currency" name="currency" required>
                        <option value="ILS" selected>ILS</option>
                        <option value="USD">USD</option>
                        <option value="EUR">EUR</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="product_name">Product Name</label>
                <input type="text" id="product_name" name="product_name" required value="Test Product">
            </div>

            <div class="row">
                <div class="form-group">
                    <label for="language">Language</label>
                    <select id="language" name="language" required>
                        <option value="en" selected>English</option>
                        <option value="he">Hebrew</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="sale_payment_method">Payment Method</label>
                    <select id="sale_payment_method" name="sale_payment_method" required>
                        <option value="multi" selected>Multi</option>
                        <option value="credit-card">Credit Card</option>
                        <option value="bit">Bit</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="sale_type">Sale Type</label>
                <select id="sale_type" name="sale_type" required>
                    <option value="sale" selected>Sale</option>
                    <option value="authorize">Authorize</option>
                </select>
            </div>

            <div class="button-group">
                <button type="submit" formaction="/generate-sale" class="btn-primary">Generate Sale</button>
                {{#if applePayEnabled}}
                <button type="submit" formaction="/generate-apple-pay-sale" class="btn-apple-pay">Apple Pay</button>
                {{else}}
                <button type="button" class="btn-apple-pay btn-apple-pay-disabled" disabled title="Set Apple Pay Merchant ID in defaults to enable">Apple Pay</button>
                {{/if}}
                {{#if googlePayEnabled}}
                <button type="submit" formaction="/generate-google-pay-sale" class="btn-primary">Google Pay</button>
                {{else}}
                <button type="button" class="btn-disabled" disabled title="Set Public Key in defaults to enable">Google Pay</button>
                {{/if}}
            </div>
        </form>

        <p class="info-text">Choose your payment method: Generate Sale for standard payment, Apple Pay, or Google Pay.</p>
        {{#unless applePayEnabled}}
        <p class="info-text" style="color: #888;">Apple Pay is disabled. Set Apple Pay Merchant ID in defaults to enable.</p>
        {{/unless}}
        {{#unless googlePayEnabled}}
        <p class="info-text" style="color: #888;">Google Pay is disabled. Set Public Key in defaults to enable.</p>
        {{/unless}}

        <p class="info-text">
            <a href="/" class="btn btn-secondary" style="margin-top: 15px;">Back to Home</a>
        </p>
    </div>
</div>

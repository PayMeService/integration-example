<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>

    <!-- PayMe SDK -->
    <script src="{{paymeSdkUrl}}"></script>

    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            margin: 0;
            padding: 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            padding: 40px;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        h1 {
            color: #333;
            margin-bottom: 10px;
        }

        .sale-info {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 30px;
        }

        .info-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #e0e0e0;
        }

        .info-item:last-child {
            border-bottom: none;
        }

        .info-label {
            font-weight: 600;
            color: #666;
        }

        .info-value {
            color: #333;
            font-weight: 500;
        }

        .payment-section {
            text-align: center;
            padding: 30px 0;
        }

        .hidden {
            display: none !important;
        }

        .availability-message {
            padding: 20px;
            background: #fff3cd;
            border: 1px solid #ffc107;
            border-radius: 8px;
            color: #856404;
            margin: 20px 0;
        }

        .error-message {
            padding: 20px;
            background: #f8d7da;
            border: 1px solid #dc3545;
            border-radius: 8px;
            color: #721c24;
            margin: 20px 0;
        }

        .success-message {
            padding: 20px;
            background: #d4edda;
            border: 1px solid #28a745;
            border-radius: 8px;
            color: #155724;
            margin: 20px 0;
        }

        .console-log {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 20px;
            margin-top: 30px;
            max-height: 300px;
            overflow-y: auto;
        }

        .console-log pre {
            margin: 0;
            font-size: 12px;
            white-space: pre-wrap;
            word-wrap: break-word;
        }

        .back-button {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 24px;
            background: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            transition: background 0.3s;
        }

        .back-button:hover {
            background: #5a6268;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>{{title}}</h1>
        </div>

        <div class="sale-info">
            <div class="info-item">
                <div class="info-label">Sale ID</div>
                <div class="info-value">{{payme_sale_id}}</div>
            </div>

            <div class="info-item">
                <div class="info-label">Payment Method</div>
                <div class="info-value">Google Pay</div>
            </div>

            <div class="info-item">
                <div class="info-label">SDK URL</div>
                <div class="info-value">{{paymeSdkUrl}}</div>
            </div>
        </div>

        <div id="availability-check" class="availability-message hidden">
            Checking Google Pay availability...
        </div>

        <div id="not-available" class="availability-message hidden">
            Google Pay is not available on this device/browser.
        </div>

        <div class="payment-section">
            <div id="payment-ready" class="hidden">
                <p>Click the button below to pay with Google Pay</p>
                <div id="pay-with-google-pay"></div>
            </div>
        </div>

        <div id="success-message" class="success-message hidden"></div>
        <div id="error-message" class="error-message hidden"></div>

        <div class="console-log">
            <strong>Payment Flow Log:</strong>
            <pre id="console-output"></pre>
        </div>

        <div style="text-align: center;">
            <a href="/" class="back-button">Back to Home</a>
        </div>
    </div>

    <script>
        const consoleOutput = document.getElementById('console-output');
        const availabilityCheck = document.getElementById('availability-check');
        const notAvailable = document.getElementById('not-available');
        const paymentReady = document.getElementById('payment-ready');
        const successMessage = document.getElementById('success-message');
        const errorMessage = document.getElementById('error-message');

        function log(message) {
            const timestamp = new Date().toLocaleTimeString();
            consoleOutput.textContent += `[${timestamp}] ${message}\n`;
            consoleOutput.parentElement.scrollTop = consoleOutput.parentElement.scrollHeight;
            console.log(message);
        }

        function showError(message) {
            errorMessage.textContent = message;
            errorMessage.classList.remove('hidden');
            log('ERROR: ' + message);
        }

        function showSuccess(message) {
            successMessage.textContent = message;
            successMessage.classList.remove('hidden');
            log('SUCCESS: ' + message);
        }

        (async function initializeGooglePay() {
            log('Initializing Google Pay integration...');
            availabilityCheck.classList.remove('hidden');

            if (!window.PayMe) {
                availabilityCheck.classList.add('hidden');
                showError('PayMe SDK not loaded. Please refresh the page.');
                return;
            }

            log('PayMe SDK loaded successfully');

            const apiKey = '{{apiKey}}';
            const saleGuid = '{{payme_sale_id}}';
            const testMode = {{#if testMode}}true{{else}}false{{/if}};

            if (!apiKey) {
                availabilityCheck.classList.add('hidden');
                showError('Public Key is missing. Configure it in defaults.');
                return;
            }

            log(`Initializing PayMe with API key: ${apiKey.substring(0, 8)}...`);
            log(`Test mode: ${testMode}`);

            try {
                const isGooglePayAvailable = await PayMe.isGooglePayAvailable(testMode);
                log(`Google Pay available: ${isGooglePayAvailable}`);

                availabilityCheck.classList.add('hidden');

                if (!isGooglePayAvailable) {
                    notAvailable.classList.remove('hidden');
                    return;
                }

                const instance = await PayMe.create(apiKey, { testMode: testMode{{#if apiUrl}}, apiUrl: '{{apiUrl}}/api'{{/if}} });
                log('PayMe instance created successfully');

                const googleSale = instance.googleSale({
                    saleGuid: saleGuid,
                    debugFn: function(message) {
                        log(`[PayMe Debug] ${message}`);
                    }
                });

                const interactionConfig = {
                    payButtonSelector: '#pay-with-google-pay',
                    buttonType: 'buy',
                    buttonColor: 'default',

                    canceled: function() {
                        log('Payment was cancelled by user');
                        showError('Payment was cancelled. You can try again by clicking the Google Pay button.');
                    },

                    paymentCompleted: function(err, sale) {
                        if (err) {
                            log(`Payment failed: ${err.message}`);
                            showError(`Payment failed: ${err.message}`);
                        } else {
                            log('Payment completed successfully!');
                            log(`Sale details: ${JSON.stringify(sale, null, 2)}`);
                            showSuccess('Payment completed successfully! ' + JSON.stringify(sale, null, 2));
                        }
                    }
                };

                log('Initializing Google Pay button...');

                await googleSale.letsRock(interactionConfig);
                log('Google Pay button initialized and ready');
                paymentReady.classList.remove('hidden');
            } catch (error) {
                availabilityCheck.classList.add('hidden');
                log(`Initialization error: ${error.message}`);
                showError(`Failed to initialize Google Pay: ${error.message}`);
            }
        })();
    </script>
</body>
</html>

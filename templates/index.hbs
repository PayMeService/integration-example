<div class="container form-container">
    <div class="form-wrapper">
        <h1>PayMe Payment Wrapper</h1>

        {{#if missing}}
        <div class="error-message">Please fill in all required defaults before proceeding.</div>
        {{/if}}

        <div class="nav-section">
            <h2>Defaults <span class="required-label">* Required</span></h2>
            <form action="/defaults" method="POST">
                {{#unless isProd}}
                <div class="form-group">
                    <label for="server">Server URL *</label>
                    <input type="text" id="server" name="server" value="{{defaults.server}}" placeholder="e.g., https://sandbox.payme.io" required>
                </div>
                {{/unless}}

                <div class="form-group">
                    <label for="partner_key">Partner Key *</label>
                    <input type="text" id="partner_key" name="partner_key" value="{{defaults.partner_key}}" placeholder="e.g., testparnerkey" required>
                </div>

                <div class="form-group">
                    <label for="seller_payme_id">Default Seller PayMe ID (MPL) *</label>
                    <input type="text" id="seller_payme_id" name="seller_payme_id" value="{{defaults.seller_payme_id}}" placeholder="e.g., MPLXXXXX-XXXXXXXX-XXXXXXXX-XXXXXXXX" required>
                </div>

                <div class="form-group">
                    <label for="apple_pay_merchant_id">Apple Pay Merchant ID <span class="optional-label">(Optional)</span></label>
                    <input type="text" id="apple_pay_merchant_id" name="apple_pay_merchant_id" value="{{defaults.apple_pay_merchant_id}}" placeholder="e.g., merchant.paymeproduction">
                </div>

                <div class="form-group">
                    <label for="public_key">Public Key <span class="optional-label">(Optional - for Apple Pay / Google Pay)</span></label>
                    <input type="text" id="public_key" name="public_key" value="{{defaults.public_key}}" placeholder="Public API key for Apple Pay / Google Pay">
                </div>

                {{#unless isProd}}
                <div class="form-group">
                    <label style="display: inline-flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                        <input type="checkbox" id="use_staging_sdk" name="use_staging_sdk" style="width: auto; margin: 0;" {{#if defaults.use_staging_sdk}}checked{{/if}}>
                        Use staging SDK URL
                    </label>
                    <div class="info-text" style="text-align: left; margin-top: 0;">
                        Selected SDK: <strong>{{paymeSdkUrl}}</strong>
                    </div>
                </div>
                {{/unless}}

                <div class="form-group">
                    <label style="display: inline-flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                        <input type="checkbox" id="test_mode" name="test_mode" style="width: auto; margin: 0;" {{#if defaults.test_mode}}checked{{/if}}>
                        Use SDK test mode
                    </label>
                </div>

                <button type="submit" class="btn btn-primary">Save Defaults</button>
            </form>

            {{#if saved}}
            <div class="success-message">Defaults saved successfully!</div>
            {{/if}}
        </div>

        <div class="nav-section">
            <h2>Actions</h2>
            <div class="nav-buttons">
                {{#if defaultsComplete}}
                <a href="/generate-sale-form" class="btn btn-primary btn-large">Generate Sale</a>
                <a href="/vas-enable-form" class="btn btn-secondary btn-large">Enable VAS</a>
                <a href="/vas-update-form" class="btn btn-secondary btn-large">Update VAS</a>
                {{else}}
                <span class="btn btn-disabled btn-large">Generate Sale</span>
                <span class="btn btn-disabled btn-large">Enable VAS</span>
                <span class="btn btn-disabled btn-large">Update VAS</span>
                <p class="info-text">Fill in required defaults above to enable actions</p>
                {{/if}}
            </div>
        </div>

        <div class="nav-section">
            <h2>Show Sale</h2>
            <div class="inline-form">
                <div class="form-group">
                    <input type="text" id="saleId" placeholder="Enter Sale ID" {{#unless defaultsComplete}}disabled{{/unless}}>
                </div>
                <button type="button" class="btn btn-primary" id="showSaleBtn" {{#unless defaultsComplete}}disabled{{/unless}}>Show</button>
            </div>
            <div class="button-group">
                {{#if applePayEnabled}}
                <button type="button" class="btn btn-primary" id="showApplePayBtn" {{#unless defaultsComplete}}disabled{{/unless}}>Apple Pay</button>
                {{else}}
                <button type="button" class="btn btn-disabled" disabled title="Set Apple Pay Merchant ID in defaults to enable">Apple Pay</button>
                {{/if}}
                {{#if googlePayEnabled}}
                <button type="button" class="btn btn-primary" id="showGooglePayBtn" {{#unless defaultsComplete}}disabled{{/unless}}>Google Pay</button>
                {{else}}
                <button type="button" class="btn btn-disabled" disabled title="Set Public Key in defaults to enable">Google Pay</button>
                {{/if}}
            </div>
            <script>
                document.getElementById('showSaleBtn').addEventListener('click', function() {
                    var saleId = document.getElementById('saleId').value;
                    if (saleId) {
                        window.location.href = '/sale/' + encodeURIComponent(saleId);
                    }
                });
                {{#if applePayEnabled}}
                document.getElementById('showApplePayBtn').addEventListener('click', function() {
                    var saleId = document.getElementById('saleId').value;
                    if (saleId) {
                        window.location.href = '/apple-pay-sale/' + encodeURIComponent(saleId);
                    }
                });
                {{/if}}
                {{#if googlePayEnabled}}
                document.getElementById('showGooglePayBtn').addEventListener('click', function() {
                    var saleId = document.getElementById('saleId').value;
                    if (saleId) {
                        window.location.href = '/google-pay-sale/' + encodeURIComponent(saleId);
                    }
                });
                {{/if}}
            </script>
        </div>

        <div class="nav-section current-defaults">
            <h2>Current Settings</h2>
            <div class="settings-grid">
                <div class="setting-item">
                    <span class="setting-label">Server:</span>
                    <span class="setting-value {{#unless defaults.server}}setting-missing{{/unless}}">{{#if defaults.server}}{{defaults.server}}{{#if isProd}} <em>(auto)</em>{{/if}}{{else}}<em>Not set</em>{{/if}}</span>
                </div>
                <div class="setting-item">
                    <span class="setting-label">Partner Key:</span>
                    <span class="setting-value {{#unless defaults.partner_key}}setting-missing{{/unless}}">{{#if defaults.partner_key}}{{defaults.partner_key}}{{else}}<em>Not set</em>{{/if}}</span>
                </div>
                <div class="setting-item">
                    <span class="setting-label">Default MPL:</span>
                    <span class="setting-value {{#unless defaults.seller_payme_id}}setting-missing{{/unless}}">{{#if defaults.seller_payme_id}}{{defaults.seller_payme_id}}{{else}}<em>Not set</em>{{/if}}</span>
                </div>
                <div class="setting-item">
                    <span class="setting-label">Apple Pay Merchant ID:</span>
                    <span class="setting-value">{{#if defaults.apple_pay_merchant_id}}{{defaults.apple_pay_merchant_id}}{{else}}<em>Not set (optional)</em>{{/if}}</span>
                </div>
                <div class="setting-item">
                    <span class="setting-label">Public Key:</span>
                    <span class="setting-value">{{#if defaults.public_key}}{{defaults.public_key}}{{else}}<em>Not set (optional)</em>{{/if}}</span>
                </div>
                <div class="setting-item">
                    <span class="setting-label">PayMe SDK URL:</span>
                    <span class="setting-value">{{paymeSdkUrl}}</span>
                </div>
                <div class="setting-item">
                    <span class="setting-label">Test Mode:</span>
                    <span class="setting-value">{{#if defaults.test_mode}}Enabled{{else}}Disabled{{/if}}</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="header with-actions">
        <h1>Sale <span class="sale-id">{{saleId}}</span></h1>
        <div class="actions">
            <a href="{{saleUrl}}" target="_blank" class="btn btn-secondary">Open in New Tab</a>
            <a href="/generate-sale-form" class="btn btn-primary">Generate New Sale</a>
        </div>
    </div>
    
    <div class="iframe-container">
        <div id="loading" class="loading">
            <div class="loading-spinner"></div>
            <p>Loading sale page...</p>
        </div>
        <iframe
            id="saleFrame"
            src=""
            title="Sale {{saleId}}"
            onload="document.getElementById('loading').style.display='none';"
            allow="payment"
        ></iframe>
        <script>
            (function() {
                const saleUrl = '{{saleUrl}}';
                const origin = encodeURIComponent(window.location.host);
                const separator = saleUrl.includes('?') ? '&' : '?';
                const urlWithOrigin = saleUrl + separator + 'origin=' + origin;
                document.getElementById('saleFrame').src = urlWithOrigin;
            })();
        </script>
    </div>
</div>

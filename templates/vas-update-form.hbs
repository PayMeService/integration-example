<div class="container form-container">
    <div class="form-wrapper">
        <h1>Update VAS</h1>
        <form id="vasUpdateForm" action="/vas-update" method="POST">
            <div class="form-group">
                <label for="payme_client_key">PayMe Client Key</label>
                <input type="text" id="payme_client_key" name="payme_client_key" value="{{defaults.partner_key}}" placeholder="e.g., Azrieli-com">
            </div>

            <div class="form-group">
                <label for="seller_payme_id">Seller PayMe ID</label>
                <input type="text" id="seller_payme_id" name="seller_payme_id" value="{{defaults.seller_payme_id}}" placeholder="e.g., MPL16822-46141Q8L-IORWDZWW-QTBRRXBJ">
            </div>

            <div class="form-group">
                <label for="vas_payme_id">VAS PayMe ID</label>
                <input type="text" id="vas_payme_id" name="vas_payme_id" required placeholder="e.g., VASL1755-093104VV-Z8HSDIK4-S56JJVRD">
            </div>

            <div class="form-group">
                <label for="websites">Websites <span class="optional-label">(comma separated)</span></label>
                <input type="text" id="websites" name="websites" required placeholder="e.g., test11.payme.io, example.com">
            </div>

            <div class="form-group">
                <label for="language">Language</label>
                <select id="language" name="language" required>
                    <option value="en" selected>English</option>
                    <option value="he">Hebrew</option>
                </select>
            </div>

            <button type="submit" class="btn-primary">Update VAS</button>
        </form>

        <p class="info-text">
            <a href="/" class="btn btn-secondary" style="margin-top: 15px;">Back to Home</a>
        </p>
    </div>
</div>
